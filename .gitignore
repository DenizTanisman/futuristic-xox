# Rust
/target
**/target
Cargo.lock.bak

# Flutter / Dart
ui/.dart_tool/
ui/.flutter-plugins
ui/.flutter-plugins-dependencies
ui/build/
ui/.pub-cache/
ui/.pub/
ui/ios/Pods/
ui/ios/.symlinks/
ui/android/.gradle/
ui/android/local.properties
ui/*.iml

# flutter_rust_bridge generated artifacts are kept under version control
# except platform build outputs above.

# Release signing material — NEVER commit (keystore + credentials live only on the release machine)
ui/android/key.properties
**/*.jks
**/*.keystore
**/upload-keystore.jks
**/*.p12
**/*.pepk
# iOS signing material
**/*.mobileprovision
**/*.cer
ui/ios/ExportOptions.plist

# Audio source drop (raw, non-ASCII names) — the app uses the renamed ASCII copies in ui/assets/audio/
sounds/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
Cargo.lock
